# syntax=docker/dockerfile:1.7
#
# MediaMTX + MXL static source, built from:
#   - qvest-digital/mediamtx@feature/mxl-static-source (PR #1)
#   - qvest-digital/mxl-dmf-demo@claude/musing-kalam-1213f8 (libmxl fork + Go bindings, PR #14)
#
# Multi-stage:
#   1. libmxl-builder : build libmxl from the fork (includes pkg-config/rpath fix)
#   2. mediamtx-builder : build mediamtx with cgo against libmxl + local Go binding
#   3. runtime : debian-slim + ffmpeg + libmxl + mediamtx
#
# Build (Apple Silicon native):
#   docker buildx build --platform linux/arm64 -t mediamtx-mxl:dev -f Dockerfile.mediamtx-mxl .

ARG DEBIAN_RELEASE=trixie-slim

# -------- 1. libmxl builder ----------
FROM debian:${DEBIAN_RELEASE} AS libmxl-builder

RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential bison flex \
      cmake ninja-build pkg-config \
      git ca-certificates curl zip unzip tar \
      libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev \
    && rm -rf /var/lib/apt/lists/*

# vcpkg (libmxl bootstrap)
RUN useradd -m mxl
USER mxl
WORKDIR /home/mxl
RUN git clone https://github.com/microsoft/vcpkg.git vcpkg \
    && ./vcpkg/bootstrap-vcpkg.sh -disableMetrics

# Pull the qvest-digital fork branch (libmxl sources + rpath fix + Go binding).
ARG MXL_REPO=https://github.com/qvest-digital/mxl-dmf-demo.git
ARG MXL_REF=claude/musing-kalam-1213f8
RUN git clone --depth=1 --branch ${MXL_REF} ${MXL_REPO} mxl

# Build libmxl (shared, release).
RUN cmake -S mxl --preset Linux-GCC-Release -DCMAKE_INSTALL_PREFIX=/usr \
    && ninja -C mxl/build/Linux-GCC-Release

USER 0:0
RUN ninja -C /home/mxl/mxl/build/Linux-GCC-Release install

# -------- 2. mediamtx builder ----------
FROM debian:${DEBIAN_RELEASE} AS mediamtx-builder

RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential pkg-config git ca-certificates curl \
      libspdlog-dev libfmt-dev \
    && rm -rf /var/lib/apt/lists/*

# Go toolchain (mediamtx go.mod requires 1.26).
ARG GO_VERSION=1.26.0
ARG TARGETARCH
RUN set -eux; \
    case "${TARGETARCH}" in \
      amd64) GOARCH=amd64 ;; \
      arm64) GOARCH=arm64 ;; \
      *) echo "unsupported arch ${TARGETARCH}"; exit 1 ;; \
    esac; \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${GOARCH}.tar.gz" \
      | tar -C /usr/local -xz
ENV PATH=/usr/local/go/bin:${PATH}

# Bring in libmxl + headers + pkg-config from stage 1.
COPY --from=libmxl-builder /usr/include/mxl /usr/include/mxl
COPY --from=libmxl-builder /usr/lib/ /usr/lib-mxl-staging/
# multiarch: copy libmxl* into the active lib dir.
RUN set -eux; \
    libdir="$(dpkg-architecture -qDEB_HOST_MULTIARCH 2>/dev/null && true)"; \
    for d in /usr/lib/${libdir} /usr/lib/aarch64-linux-gnu /usr/lib/x86_64-linux-gnu /usr/lib; do \
      if [ -d "$d" ]; then DEST="$d"; break; fi; \
    done; \
    cp -a /usr/lib-mxl-staging/libmxl* "$DEST/" 2>/dev/null || true; \
    cp -a /usr/lib-mxl-staging/pkgconfig/libmxl* /usr/lib/pkgconfig/ 2>/dev/null || true; \
    find /usr/lib-mxl-staging -name 'libmxl*' -exec cp -a {} "$DEST/" \; ; \
    find /usr/lib-mxl-staging -name 'libmxl*.pc' -exec cp -a {} /usr/lib/pkgconfig/ \; ; \
    ldconfig
ENV PKG_CONFIG_PATH=/usr/lib/pkgconfig

# Fetch mediamtx fork + Go binding source.
ARG MEDIAMTX_REPO=https://github.com/qvest-digital/mediamtx.git
ARG MEDIAMTX_REF=feature/mxl-static-source
ARG GOBIND_REPO=https://github.com/qvest-digital/mxl-dmf-demo.git
ARG GOBIND_REF=claude/musing-kalam-1213f8

WORKDIR /src
RUN git clone --depth=1 --branch ${MEDIAMTX_REF} ${MEDIAMTX_REPO} mediamtx \
 && git clone --depth=1 --branch ${GOBIND_REF}  ${GOBIND_REPO}  mxl-binding

# Point mediamtx at the local checkout of the Go binding (PR #14 unmerged).
WORKDIR /src/mediamtx
RUN go mod edit -replace github.com/qvest-digital/mxl-dmf-demo/go=/src/mxl-binding/go \
 && go mod download \
 && go mod tidy || true

# Generate embeds: VERSION, hls.min.js, rpicam binaries.
RUN go generate ./...

# Build mediamtx with cgo enabled.
ENV CGO_ENABLED=1
RUN go build -o /out/mediamtx .

# Smoke-check: dynamic linkage.
RUN ldd /out/mediamtx | grep -E 'libmxl|not found' || true

# -------- 3a. producer (mxl-gst-testsrc) runtime ----------
FROM debian:${DEBIAN_RELEASE} AS producer

RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates dumb-init \
      libspdlog1.15 libfmt10 \
      gstreamer1.0-plugins-good gstreamer1.0-plugins-base gstreamer1.0-x \
      libpango-1.0-0 libpangocairo-1.0-0 \
    && rm -rf /var/lib/apt/lists/*

# libmxl runtime libs + mxl-gst-testsrc binary.
COPY --from=libmxl-builder /usr/lib/ /tmp/libmxl-stage/
COPY --from=libmxl-builder /usr/bin/mxl-gst-testsrc /usr/bin/mxl-gst-testsrc
COPY --from=libmxl-builder /usr/bin/mxl-info        /usr/bin/mxl-info
RUN set -eux; \
    for d in /usr/lib/aarch64-linux-gnu /usr/lib/x86_64-linux-gnu /usr/lib; do \
      if [ -d "$d" ]; then DEST="$d"; break; fi; \
    done; \
    find /tmp/libmxl-stage -name 'libmxl*.so*' -exec cp -a {} "$DEST/" \; ; \
    rm -rf /tmp/libmxl-stage; \
    ldconfig

ENTRYPOINT ["/usr/bin/dumb-init", "--", "/usr/bin/mxl-gst-testsrc"]

# -------- 3b. mediamtx runtime ----------
FROM debian:${DEBIAN_RELEASE} AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
      ffmpeg ca-certificates dumb-init \
      libspdlog1.15 libfmt10 \
    && rm -rf /var/lib/apt/lists/*

# libmxl shared libs.
COPY --from=libmxl-builder /usr/lib/ /tmp/libmxl-stage/
RUN set -eux; \
    for d in /usr/lib/aarch64-linux-gnu /usr/lib/x86_64-linux-gnu /usr/lib; do \
      if [ -d "$d" ]; then DEST="$d"; break; fi; \
    done; \
    find /tmp/libmxl-stage -name 'libmxl*.so*' -exec cp -a {} "$DEST/" \; ; \
    rm -rf /tmp/libmxl-stage; \
    ldconfig

COPY --from=mediamtx-builder /out/mediamtx /usr/local/bin/mediamtx

# Expose mediamtx defaults: RTSP 8554, RTMP 1935, HLS 8888, WebRTC 8889, SRT 8890.
EXPOSE 8554 1935 8888 8889 8890

ENTRYPOINT ["/usr/bin/dumb-init", "--", "/usr/local/bin/mediamtx"]
CMD ["/mediamtx.yml"]
